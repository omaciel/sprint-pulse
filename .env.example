# Copy to .env and fill in real values, then `source .env` (or use direnv).
# .env is gitignored.

# Required — Jira API credentials
# Generate a token at: https://id.atlassian.com/manage-profile/security/api-tokens
export JIRA_USERNAME="you@example.com"
export JIRA_API_TOKEN="your-api-token-here"

# Optional — override default paths (defaults are project-relative)
# export SPRINT_PULSE_DATA="$HOME/somewhere/else/time-off.md"
# export SPRINT_PULSE_OUTPUT="$HOME/somewhere/else/report.html"
