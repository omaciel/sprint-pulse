# Copy to .env and fill in real values, then `source .env` (or use direnv).
# .env is gitignored. On the desktop the Jira token is stored in your OS keychain
# instead — these are mainly for the container / headless runs.

# Jira API credentials (token: https://id.atlassian.com/manage-profile/security/api-tokens)
export JIRA_USERNAME="you@example.com"
export JIRA_API_TOKEN="your-api-token-here"

# Optional — override where the SQLite database lives
# export SPRINT_PULSE_DB="$HOME/somewhere/sprint-pulse.db"
# export XDG_DATA_HOME="$HOME/.local/share"

# Optional — host/port for the web server
# export SPRINT_PULSE_HOST="0.0.0.0"
# export SPRINT_PULSE_PORT="8765"

# Optional — try everything offline with mocked Jira + example data
# export SPRINT_PULSE_DEMO="1"
